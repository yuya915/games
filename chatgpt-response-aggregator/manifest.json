{
  "manifest_version": 3,
  "name": "ChatGPT回答自動集計ツール",
  "version": "1.0.0",
  "description": "ChatGPTの回答を自動取得し、Googleフォームへ送信するツール",
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://docs.google.com/forms/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "ChatGPT回答集計"
  },
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*"],
      "js": ["content.js"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
